{
  "expo": {
    "name": "NEXUS",
    "slug": "nexus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080816"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.nexus.tdah",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "O NEXUS usa o microfone para você falar suas tarefas.",
        "NSSpeechRecognitionUsageDescription": "O NEXUS converte sua voz em texto para entender suas tarefas.",
        "NSCameraUsageDescription": "O NEXUS usa a camera para ler textos e te ajudar com OCR.",
        "NSPhotoLibraryUsageDescription": "O NEXUS acessa sua galeria para extrair texto de imagens."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080816"
      },
      "package": "com.nexus.tdah",
      "permissions": [
        "RECORD_AUDIO",
        "CAMERA",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SYSTEM_ALERT_WINDOW"
      ]
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "O NEXUS acessa suas fotos para ler texto com OCR.",
          "cameraPermission": "O NEXUS usa sua camera para capturar texto com OCR."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#8B5CF6",
          "sounds": []
        }
      ]
    ],
    "scheme": "nexus",
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7ad624e1-2ca1-49c3-98e7-2ff7531cfbf4"
      }
    },
    "owner": "canucavai"
  }
}
